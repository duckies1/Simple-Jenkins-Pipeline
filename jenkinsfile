pipeline {
    agent any

    environment {
        IMAGE_NAME = "simple-html-app"
        CONTAINER_NAME = "simple-html-container"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    sh "docker build -t ${IMAGE_NAME}:latest ."
                }
            }
        }

        stage('Test Docker Container') {
            steps {
                script {
                    // Run container temporarily for testing
                    sh "docker rm -f test-container"
                    sh "docker run -d --name test-container -p 8081:80 ${IMAGE_NAME}:latest"
                    sh "sleep 5"
                    // sh "curl -f http://localhost:8081"
                    sh "docker exec test-container curl -f http://localhost"
                    sh "docker rm -f test-container"
                }
            }
        }

        stage('Deploy') {
            steps { 
                script {
                    // Stop old container if exists
                    sh "docker rm -f ${CONTAINER_NAME} || true"

                    // Run new container
                    sh "docker run -d --name ${CONTAINER_NAME} -p 8080:80 ${IMAGE_NAME}:latest"
                }
            }
        }
    }

    post {
        success {
            echo "Application successfully deployed at http://localhost:8080"
        }
        failure {
            echo "Pipeline failed!"
        }
    }
}